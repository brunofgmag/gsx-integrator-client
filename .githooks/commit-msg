#!/bin/sh
# commit-msg: enforce the Conventional Commits format on the subject line.
#   <type>[(scope)][!]: <description>
# See https://www.conventionalcommits.org
#
# Installed via:  git config core.hooksPath .githooks  (shared with pre-commit)

msg_file="$1"

# Subject = first non-comment, non-blank line of the message.
subject=$(grep -v '^#' "$msg_file" | sed '/^[[:space:]]*$/d' | head -n1)

# Let git's own auto-generated messages through (merges, reverts, fixups).
case "$subject" in
  "Merge "*|"Revert "*|"fixup! "*|"squash! "*|"amend! "*)
    exit 0 ;;
esac

# type(scope)!: description   — scope and "!" optional, description required.
types='feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert'
pattern="^(${types})(\([a-z0-9._/-]+\))?(!)?: .+"

if printf '%s' "$subject" | grep -Eq "$pattern"; then
  exit 0
fi

cat >&2 <<EOF

  ✖ Commit message does not follow Conventional Commits.

    Got:      $subject

    Expected: <type>[(scope)][!]: <description>
    Types:    feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert
    Examples: feat(gsx): add jetway request handling
              fix: correct LVar read offset
              docs: update build instructions
              feat!: drop MSFS 2020 support   (! marks a breaking change)

EOF
exit 1
